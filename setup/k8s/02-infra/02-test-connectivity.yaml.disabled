apiVersion: v1
kind: ConfigMap
metadata:
  name: connectivity-monitor-script
  namespace: infra
data:
  server.py: |
    import http.server
    import socketserver
    import json
    import subprocess
    import time
    import sys
    import os

    # Ensure we serve files from the directory where index.html is mounted
    os.chdir('/app')

    PORT = 8000

    class Handler(http.server.SimpleHTTPRequestHandler):
        def do_GET(self):
            if self.path == '/api/ping':
                self.send_response(200)
                self.send_header('Content-type', 'application/json')
                self.end_headers()

                # We check internal pod health + host connectivity
                host = "192.168.2.1"
                try:
                    # Simple single ping with 1s timeout
                    output = subprocess.check_output(["ping", "-c", "1", "-W", "1", host], stderr=subprocess.STDOUT)
                    status = "ok"
                    latency = "N/A"
                    try:
                        # Extract time=X.X ms
                        latency_str = str(output).split("time=")[1].split(" ")[0]
                        latency = float(latency_str)
                    except:
                        pass
                except subprocess.CalledProcessError:
                    status = "fail"
                    latency = -1

                response = {
                    "status": status,
                    "target": host,
                    "latency": latency,
                    "timestamp": time.time(),
                    "pod": socketserver.socket.gethostname() # Return pod name to verify load balancing
                }
                self.wfile.write(json.dumps(response).encode('utf-8'))
            else:
                # Serve static files (index.html)
                super().do_GET()

    with socketserver.TCPServer(("", PORT), Handler) as httpd:
        print(f"Serving at port {PORT}")
        httpd.serve_forever()

  index.html: |
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Traefik Resilience Monitor</title>
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <style>
            body { background-color: #0f172a; color: #e2e8f0; font-family: monospace; padding: 20px; }
            .card { background: #1e293b; padding: 20px; border-radius: 8px; margin-bottom: 20px; }
            .status-ok { color: #4ade80; }
            .status-fail { color: #f87171; }
            h1 { margin-top: 0; }
            .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; }
            .stat { font-size: 2em; font-weight: bold; }
            .stat-label { font-size: 0.8em; color: #94a3b8; }
        </style>
    </head>
    <body>
        <div class="card">
            <h1>Ingress / Network Heartbeat</h1>
            <div class="grid">
                <div>
                    <div class="stat-label">Status</div>
                    <div id="status" class="stat">CONNECTING...</div>
                </div>
                <div>
                    <div class="stat-label">Uptime (Valid Pings)</div>
                    <div id="uptime" class="stat">0s</div>
                </div>
                <div>
                    <div class="stat-label">Failures</div>
                    <div id="failures" class="stat" style="color: #f87171">0</div>
                </div>
                <div>
                    <div class="stat-label">Latency (Pod -> Host)</div>
                    <div id="latency" class="stat">0 ms</div>
                </div>
                <div>
                    <div class="stat-label">Current Pod</div>
                    <div id="podname" style="font-size: 1em; padding-top:10px;">-</div>
                </div>
            </div>
        </div>

        <div class="card" style="height: 300px; position: relative;">
            <canvas id="latencyChart"></canvas>
        </div>

        <script>
            let successfulPings = 0;
            let failureCount = 0;
            let startTime = Date.now();
            let isConnected = true;

            const ctx = document.getElementById('latencyChart').getContext('2d');
            const chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: [{
                        label: 'Latency (ms)',
                        data: [],
                        borderColor: '#38bdf8',
                        tension: 0.1
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    animation: false,
                    responsive: true,
                    scales: { y: { beginAtZero: true, grid: { color: '#334155' } }, x: { display: false } }
                }
            });

            async function check() {
                const start = performance.now();
                try {
                    // Timeout set strictly to detect freezes
                    const controller = new AbortController();
                    const timeoutId = setTimeout(() => controller.abort(), 2000);

                    const res = await fetch('/api/ping', { signal: controller.signal });
                    const data = await res.json();

                    document.getElementById('podname').innerText = data.pod;

                    if(data.status === 'ok') {
                        document.getElementById('status').innerText = "ONLINE";
                        document.getElementById('status').className = "stat status-ok";
                        document.getElementById('latency').innerText = data.latency + " ms";

                        successfulPings++;
                        document.getElementById('uptime').innerText = successfulPings + "s";

                        // Chart update
                        if(chart.data.labels.length > 50) {
                            chart.data.labels.shift();
                            chart.data.datasets[0].data.shift();
                        }
                        chart.data.labels.push(new Date().toLocaleTimeString());
                        chart.data.datasets[0].data.push(data.latency);
                        chart.update();

                    } else {
                        throw new Error("Host Unreachable form Pod");
                    }

                } catch (e) {
                    failureCount++;
                    document.getElementById('status').innerText = "FAILURE: " + e.message;
                    document.getElementById('status').className = "stat status-fail";
                    document.getElementById('failures').innerText = failureCount;

                    // Mark failure on chart
                    if(chart.data.labels.length > 50) {
                        chart.data.labels.shift();
                        chart.data.datasets[0].data.shift();
                    }
                    chart.data.labels.push(new Date().toLocaleTimeString());
                    chart.data.datasets[0].data.push(NaN); // Gap in chart
                    chart.update();
                }
            }

            setInterval(check, 1000);
        </script>
    </body>
    </html>

---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: connectivity-monitor
  namespace: infra
spec:
  replicas: 1
  selector:
    matchLabels:
      app: connectivity-monitor
  template:
    metadata:
      labels:
        app: connectivity-monitor
    spec:
      containers:
      - name: python
        image: python:3.11-alpine
        command: ["python3", "-u", "/app/server.py"]
        ports:
        - containerPort: 8000
        resources:
          limits:
            memory: "64Mi"
            cpu: "50m"
        volumeMounts:
        - name: script-volume
          mountPath: /app
      volumes:
      - name: script-volume
        configMap:
          name: connectivity-monitor-script

---
apiVersion: v1
kind: Service
metadata:
  name: connectivity-monitor
  namespace: infra
spec:
  selector:
    app: connectivity-monitor
  ports:
  - port: 8000
    targetPort: 8000
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: connectivity-monitor
  namespace: infra
spec:
  ingressClassName: traefik
  tls:
  - hosts:
    - "test.media.lan"
    secretName: media-lan-tls
  rules:
  - host: "test.media.lan"
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: connectivity-monitor
            port:
              number: 8000
