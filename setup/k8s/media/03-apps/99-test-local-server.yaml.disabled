apiVersion: v1
kind: Endpoints
metadata:
  name: test
  namespace: media
subsets:
  - addresses:
      - ip: "${DOCKER_HOST_IP}"
    ports:
      - name: webui
        port: 4000
        protocol: TCP
---
apiVersion: v1
kind: Service
metadata:
  name: test
  namespace: media
spec:
  ports:
    - name: webui
      port: 80
      targetPort: 4000
      protocol: TCP
---
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: test
  namespace: media
  annotations:
    kubernetes.io/ingress.class: traefik-media
spec:
  entryPoints:
    - web
    - websecure
    - web-wan
    - websecure-wan
  routes:
    - match: Host(`test.media.lan`) || Host(`media.${WAN_HOSTNAME}`) || Host(`${WAN_HOSTNAME}`) || Host(`localhost`)
      kind: Rule
      services:
        - name: test
          port: 80
    - match: Host(`www.${WAN_HOSTNAME}`)
      kind: Rule
      middlewares:
        - name: www-redirect
          namespace: media
      services:
        - name: test
          port: 80
