# General
.DS_Store
/System Volume Information
/media/*
!/media/.gitkeep

# Secrets & Environment
*.env
*.key
*.crt
*.pem
*.pfx
*.srl

# Dotfiles
/.*
!/.vscode/
!/.gitignore

# Configs
/configs/*
!/configs/bind/
!/configs/home/
!/configs/kind/

# Specific Config Exclusions
/configs/bind/cache
/configs/bind/config/named.conf.local
/configs/bind/config/zones
!configs/bind/config/zones/.gitkeep
/configs/bind/log
